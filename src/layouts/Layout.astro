---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="border-b border-slate-100 py-4 px-8 flex justify-between items-center bg-white sticky top-0 z-50">
			<div id="header-logo" class="text-xl font-black text-blue-800 uppercase tracking-tighter">
				Project Name
			</div>
			<nav class="hidden md:flex space-x-8 font-bold text-slate-600 text-sm uppercase tracking-wide">
				<a href="#" class="hover:text-blue-600 transition-colors">Services</a>
				<a href="#" class="hover:text-blue-600 transition-colors">Areas Served</a>
				<!-- DYNAMIC PHONE NUMBER -->
				<a href="tel:7025550123" id="header-phone" class="text-blue-600 flex items-center">
					📞 (702) 555-0123
				</a>
			</nav>
		</header>

		<slot />

		<script>
			function syncHeader() {
				const data = localStorage.getItem('seoData');
				if (data) {
					const { targetKeyword } = JSON.parse(data);
					const logo = document.getElementById('header-logo');
					const phoneLink = document.getElementById('header-phone');
					
					if (logo && targetKeyword) {
						logo.innerText = targetKeyword;
					}

					// Logic to swap phone numbers based on location keyword
					if (phoneLink && targetKeyword) {
						if (targetKeyword.toLowerCase().includes('fairfax')) {
							phoneLink.innerText = "📞 (703) 555-0199";
							phoneLink.setAttribute('href', 'tel:7035550199');
						} else {
							phoneLink.innerText = "📞 (702) 555-0123";
							phoneLink.setAttribute('href', 'tel:7025550123');
						}
					}
				}
			}

			window.addEventListener('load', syncHeader);
			window.addEventListener('storage', syncHeader);
		</script>
	</body>
</html>
