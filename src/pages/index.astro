---
import Layout from '../layouts/Layout.astro';
// In a full setup, you would fetch data here using:
// const response = await fetch(`https://your-api.com/site?domain=${Astro.url.hostname}`);
// const data = await response.json();
---

<Layout title="Project Landing Page">
	<main class="bg-white">
		<section class="py-32 px-4 bg-gradient-to-b from-blue-50 to-white text-center border-b border-slate-100">
			<h1 id="hero-title" class="text-6xl font-black tracking-tighter text-blue-900 uppercase italic lg:text-8xl mb-6">Loading Factory...</h1>
			<p id="hero-desc" class="text-xl text-slate-600 max-w-2xl mx-auto font-medium">Connecting to Purple Media Cloud...</p>
		</section>

		<section class="py-20 px-8 border-b border-slate-50">
			<div class="max-w-4xl mx-auto">
				<h2 class="text-3xl font-bold mb-10 text-center uppercase tracking-tight text-slate-900">Why Choose Us</h2>
				<ul id="why-list" class="grid md:grid-cols-2 gap-6"></ul>
			</div>
		</section>
	</main>
</Layout>

<script>
	async function syncLiveContent() {
		// Replace this URL with your Supabase or API endpoint later
		const API_URL = 'https://api.jsonbin.io/v3/b/YOUR_BIN_ID'; 
		
		try {
			const res = await fetch(API_URL);
			const { record: data } = await res.json();

			if (data) {
				document.getElementById('hero-title').innerText = data.targetKeyword || "Expert Services";
				document.getElementById('hero-desc').innerText = `Professional ${data.targetKeyword} services available 24/7.`;
				
				const whyList = document.getElementById('why-list');
				whyList.innerHTML = data.whyChooseUs.map(item => `
					<li class="flex items-center space-x-3 text-slate-700 bg-slate-50 p-4 rounded-xl border border-slate-100 shadow-sm">
						<span class="text-blue-600 font-bold">✔</span>
						<span class="font-medium">${item}</span>
					</li>
				`).join('');
			}
		} catch (e) {
			console.log("Waiting for dashboard push...");
		}
	}

	window.addEventListener('load', syncLiveContent);
</script>
