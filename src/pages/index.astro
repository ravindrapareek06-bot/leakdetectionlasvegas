---
import Layout from '../layouts/Layout.astro';
---

<Layout title="#1 Rated Leak Detection Las Vegas | Expert Water Leak Repair">
    <section class="hero">
        <h1>Water Leak Detection Specialists in Las Vegas</h1>
        <p>Non-Invasive Technology. Precise Accuracy. Saved Foundations.</p>
        <a href="tel:7025550123" class="cta-button">Get Emergency Help Now</a>
    </section>

    <section id="services" style="padding: 80px 0;">
        <div class="container">
            <div class="section-title">
                <h2>Our Specialized Solutions</h2>
                <p>Targeting the most common water issues in the Mojave Desert environment.</p>
            </div>
            <div class="services-grid">
                <div class="service-card">
                    <h3>Slab Leak Detection</h3>
                    <p>We use ultrasonic sensors to pinpoint leaks under your concrete foundation without damaging your flooring.</p>
                    <a href="/slab-leak-detection" style="color: var(--primary); font-weight:bold;">View Service Detail →</a>
                </div>
                <div class="service-card">
                    <h3>Pool & Spa Leak Detection</h3>
                    <p>Don't let a cracked pipe drain your budget. We provide pressure testing and dye testing for all LV pools.</p>
                    <a href="/pool-leak-detection" style="color: var(--primary); font-weight:bold;">View Service Detail →</a>
                </div>
                <div class="service-card">
                    <h3>Underground Main Line Repair</h3>
                    <p>Specialized equipment to find exterior leaks between the meter and your home with zero guesswork.</p>
                    <a href="/main-line-repair" style="color: var(--primary); font-weight:bold;">View Service Detail →</a>
                </div>
            </div>
        </div>
    </section>

    <section style="padding: 80px 0; background: white;">
        <div class="container">
            <div class="section-title">
                <h2>The Expert Advantage</h2>
                <p>Why we are the preferred choice for Las Vegas homeowners and property managers.</p>
            </div>
            <table class="comparison-table">
                <thead>
                    <tr>
                        <th>Feature</th>
                        <th>Standard Plumbers</th>
                        <th>Expert Leak Detection LV</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Detection Method</td>
                        <td>Visual Guessing / Tearing Out Drywall</td>
                        <td>Non-Invasive Acoustic & Thermal Imaging</td>
                    </tr>
                    <tr>
                        <td>Accuracy</td>
                        <td>Approximate Area</td>
                        <td>Precise Within Inches</td>
                    </tr>
                    <tr>
                        <td>Equipment</td>
                        <td>Basic Snake & Camera</td>
                        <td>Industrial Ultrasonic Sensors</td>
                    </tr>
                    <tr>
                        <td>Founder-Led Quality</td>
                        <td>Rotational Technicians</td>
                        <td>Direct Oversight on Every Major Job</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </section>

    <section id="areas" class="areas-section">
        <div class="container">
            <h2>Service Areas in Southern Nevada</h2>
            <p>Establishing topical and geographic authority across the valley.</p>
            <div style="display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-top: 30px;">
                <a href="/summerlin" style="color: white; text-decoration: none; border: 1px solid white; padding: 10px 20px;">Summerlin</a>
                <a href="/henderson" style="color: white; text-decoration: none; border: 1px solid white; padding: 10px 20px;">Henderson</a>
                <a href="/north-las-vegas" style="color: white; text-decoration: none; border: 1px solid white; padding: 10px 20px;">North Las Vegas</a>
                <a href="/spring-valley" style="color: white; text-decoration: none; border: 1px solid white; padding: 10px 20px;">Spring Valley</a>
                <a href="/enterprise" style="color: white; text-decoration: none; border: 1px solid white; padding: 10px 20px;">Enterprise</a>
            </div>
        </div>
    </section>
</Layout>