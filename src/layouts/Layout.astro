---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Professional leak detection in Las Vegas. Specializing in slab leaks, pool leaks, and underground water line repair." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    
    <!-- Advanced Local Business Schema -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "PlumbingService",
      "name": "Expert Leak Detection Las Vegas",
      "description": "Professional non-invasive leak detection services in Las Vegas, specializing in slab leaks and pool leaks.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Las Vegas",
        "addressRegion": "NV",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 36.1699,
        "longitude": -115.1398
      },
      "url": "https://leakdetectionlasvegas.vercel.app",
      "serviceArea": [
        {"@type": "City", "name": "Las Vegas"},
        {"@type": "City", "name": "Henderson"},
        {"@type": "City", "name": "Summerlin"},
        {"@type": "City", "name": "North Las Vegas"}
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Leak Detection Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Slab Leak Detection" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Pool Leak Detection" } }
        ]
      }
    }
    </script>

    <style is:global>
        :root { --primary: #0056b3; --secondary: #d9534f; --dark: #333; --light: #f4f4f4; }
        body { font-family: 'Helvetica Neue', Arial, sans-serif; margin: 0; color: var(--dark); line-height: 1.6; }
        header { background: white; border-bottom: 3px solid var(--primary); padding: 10px 0; position: sticky; top: 0; z-index: 1000; }
        .container { max-width: 1200px; margin: auto; padding: 0 20px; }
        .navbar { display: flex; justify-content: space-between; align-items: center; }
        .logo { font-size: 24px; font-weight: 900; color: var(--primary); text-decoration: none; }
        .nav-links { list-style: none; display: flex; gap: 20px; margin: 0; }
        .nav-links a { text-decoration: none; color: var(--dark); font-weight: bold; }
        
        .hero { background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1584622650111-993a426fbf0a?auto=format&fit=crop&q=80&w=1200') center/cover; color: white; padding: 100px 20px; text-align: center; }
        .hero h1 { font-size: 3rem; margin-bottom: 10px; }
        
        .section-title { text-align: center; margin-bottom: 40px; }
        .section-title h2 { color: var(--primary); font-size: 2.5rem; }

        .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; }
        .service-card { background: var(--light); padding: 30px; border-radius: 8px; border-bottom: 5px solid var(--primary); transition: 0.3s; }
        .service-card:hover { transform: translateY(-5px); }
        .service-card h3 { margin-top: 0; }

        .comparison-table { width: 100%; border-collapse: collapse; margin-top: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .comparison-table th { background: var(--primary); color: white; padding: 15px; }
        .comparison-table td { padding: 15px; border-bottom: 1px solid #ddd; text-align: center; }
        .comparison-table td:first-child { text-align: left; font-weight: bold; }

        .areas-section { background: var(--dark); color: white; padding: 50px 20px; text-align: center; }
        footer { background: #222; color: #ccc; padding: 20px; text-align: center; font-size: 0.9rem; }
        .cta-button { background: var(--secondary); color: white; padding: 15px 30px; text-decoration: none; border-radius: 5px; font-weight: bold; display: inline-block; margin-top: 20px; }
    </style>
</head>
<body>

<header>
    <div class="container navbar">
        <a href="/" class="logo">EXPERT LEAK DETECTION LV</a>
        <ul class="nav-links">
            <li><a href="#services">Services</a></li>
            <li><a href="#areas">Areas Served</a></li>
            <li><a href="tel:7025550123">📞 (702) 555-0123</a></li>
        </ul>
    </div>
</header>

<main>
    <slot />
</main>

<footer>
    <div class="container">
        <p>&copy; {new Date().getFullYear()} Expert Leak Detection Las Vegas. A Purple Media Digital Asset.</p>
    </div>
</footer>

</body>
</html>