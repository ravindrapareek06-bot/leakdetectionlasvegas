---
import AdminLayout from '../layouts/AdminLayout.astro';
---

<AdminLayout title="Purple Media | Site Manager">
  <div class="flex h-screen bg-slate-900 font-sans text-white">
    
    <!-- SIDEBAR -->
    <aside class="w-80 border-r border-slate-800 flex flex-col">
      <div class="p-8">
        <h2 class="text-2xl font-black tracking-tighter text-blue-400 italic">WEBSITE FACTORY</h2>
      </div>

      <div class="px-6 space-y-6">
        <div>
          <label class="text-[10px] uppercase tracking-widest text-slate-500 font-black mb-4 block">Deployed Sites</label>
          <div class="space-y-2">
            <a href="https://leak-lv.vercel.app" target="_blank" class="block p-4 bg-slate-800 rounded-2xl border border-slate-700 hover:border-blue-500 transition-all">
              <p class="text-xs font-bold">leak-lv.vercel.app</p>
              <span class="text-[10px] text-green-400">● Live & Synced</span>
            </a>
            <a href="https://water-fairfax.vercel.app" target="_blank" class="block p-4 bg-slate-800 rounded-2xl border border-slate-700 hover:border-blue-500 transition-all">
              <p class="text-xs font-bold">water-fairfax.vercel.app</p>
              <span class="text-[10px] text-green-400">● Live & Synced</span>
            </a>
          </div>
        </div>
      </div>

      <div class="mt-auto p-6">
        <button id="globalPush" class="w-full py-4 bg-blue-600 hover:bg-blue-500 rounded-2xl font-black uppercase tracking-widest text-xs shadow-lg shadow-blue-600/20 transition-all active:scale-95">
          🚀 Sync All Sites
        </button>
      </div>
    </aside>

    <!-- EDITOR -->
    <main class="flex-1 bg-white text-slate-900 p-12 overflow-y-auto">
      <div class="max-w-3xl mx-auto space-y-12">
        <header class="flex justify-between items-end">
          <div>
            <h1 class="text-4xl font-black tracking-tight italic">Content Editor</h1>
            <p class="text-slate-500 font-medium">Updates push instantly to Vercel via Database.</p>
          </div>
        </header>

        <section class="space-y-6">
          <div class="grid grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase text-slate-400">Primary Keyword</label>
              <input type="text" id="targetKeyword" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 font-bold" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold uppercase text-slate-400">Target Phone</label>
              <input type="text" id="phoneNumber" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 font-bold" />
            </div>
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold uppercase text-slate-400">Why Choose Us (Selling Points)</label>
            <textarea id="whyChooseUs" class="w-full p-4 bg-slate-50 border border-slate-200 rounded-2xl outline-none focus:ring-2 focus:ring-blue-500 font-bold h-40"></textarea>
          </div>
        </section>
      </div>
    </main>
  </div>
</AdminLayout>

<script>
  const pushBtn = document.getElementById('globalPush');

  pushBtn?.addEventListener('click', async () => {
    const data = {
      targetKeyword: (document.getElementById('targetKeyword') as HTMLInputElement).value,
      phoneNumber: (document.getElementById('phoneNumber') as HTMLInputElement).value,
      whyChooseUs: (document.getElementById('whyChooseUs') as HTMLTextAreaElement).value.split('\n').filter(l => l.trim() !== "")
    };

    // Logic: This would be your fetch('https://your-database-api.com/update')
    localStorage.setItem('seoData', JSON.stringify(data));
    
    alert('🚀 Syncing with Cloud... All Vercel sites updating now.');
  });
</script>
